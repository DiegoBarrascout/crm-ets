<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="formulario_inscripcion" name="Formulario de Inscripción">
        <t t-call="website.layout">
            <div class="container mt-4 mb-4">
                <h1 class="text-center mb-4">Formulario de Inscripción Escuela Técnica Superior Kinal</h1>
                <div class="row justify-content-center">
                    <div class="col-md-8">

                        <div class="alert alert-info">
                            <p><strong>Envía tu comprobante de pago y copia de tu DPI al correo o WhatsApp:</strong></p>
                            <ul>
                                <li>Correo: <a href="mailto:Infoets@kinal.org.gt">Infoets@kinal.org.gt</a></li>
                                <li>WhatsApp: <a href="http://bit.ly/escuelats">http://bit.ly/escuelats</a></li>
                            </ul>
                        </div>

                        <!-- Indicador de pasos -->
                        <div class="d-flex justify-content-between mb-4">
                            <div class="text-center" id="ind-1">
                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold" style="width:35px;height:35px;background:#008f8c;color:white;">1</div>
                                <div class="small mt-1">Datos Personales</div>
                            </div>
                            <div class="text-center" id="ind-2">
                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold" style="width:35px;height:35px;background:#ccc;color:white;">2</div>
                                <div class="small mt-1">Info Adicional</div>
                            </div>
                            <div class="text-center" id="ind-3">
                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold" style="width:35px;height:35px;background:#ccc;color:white;">3</div>
                                <div class="small mt-1">Datos Laborales</div>
                            </div>
                            <div class="text-center" id="ind-4">
                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold" style="width:35px;height:35px;background:#ccc;color:white;">4</div>
                                <div class="small mt-1">Condiciones</div>
                            </div>
                        </div>

                        <form action="/carreras-tecnicas/submit" method="post" id="inscripcion-form">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <input type="hidden" name="token" t-att-value="lead.x_token if lead else ''"/>

                            <!-- PASO 1 -->
                            <div class="step" id="step-1">
                                <h4 class="mb-3" style="color:#008f8c;">Paso 1: Datos Personales</h4>

                                <div class="mb-3">
                                    <label class="form-label">Nombre Completo</label>
                                    <input type="text" class="form-control bg-light" t-att-value="lead.name or lead.contact_name or lead.partner_name or ''" readonly="1"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Correo electrónico</label>
                                    <input type="text" class="form-control bg-light" t-att-value="lead.email_from or ''" readonly="1"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Número de teléfono *</label>
                                    <input type="text" name="telefono" class="form-control" t-att-value="lead.phone or ''" required="1"/>
                                    <small class="text-muted">Sin "-" ni espacios.</small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">WhatsApp *</label>
                                    <div>
                                        <input type="radio" name="whatsapp" value="si" required="1"/> Sí
                                        <input type="radio" name="whatsapp" value="no" class="ms-3"/> No
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Trabajador que lo atendió</label>
                                    <input type="text" class="form-control bg-light" t-att-value="lead.x_trabajadorQueAtendio or ''" readonly="1"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Técnico Universitario</label>
                                    <input type="text" class="form-control bg-light" t-att-value="lead.x_CarreraISTMO or ''" readonly="1"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Carrera Técnica</label>
                                    <input type="text" class="form-control bg-light" t-att-value="lead.x_CarreraTecnica or ''" readonly="1"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Jornada *</label>
                                    <div>
                                        <input type="radio" name="jornada" value="matutina" required="1"/> Matutina - sábados (08:00 a 12:30)
                                    </div>
                                    <div>
                                        <input type="radio" name="jornada" value="vespertina"/> Vespertina - sábados (13:00 a 17:30)
                                    </div>
                                </div>
                                <div class="text-end">
                                    <button type="button" class="btn btn-primary" onclick="nextStep(1)">Siguiente →</button>
                                </div>
                            </div>

                            <!-- PASO 2 -->
                            <div class="step d-none" id="step-2">
                                <h4 class="mb-3" style="color:#008f8c;">Paso 2: Información Adicional</h4>

                                <div class="mb-3">
                                    <label class="form-label">Edad (en número)</label>
                                    <input type="number" name="edad_numero" id="edad_numero" class="form-control" style="width:100px" oninput="actualizarEdad(this.value)"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Edad *</label>
                                    <div>
                                        <input type="radio" name="edad" id="edad_menor" value="menor"/> Menor de edad
                                        <input type="radio" name="edad" id="edad_mayor" value="mayor" class="ms-3"/> Mayor de edad
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Género *</label>
                                    <div>
                                        <input type="radio" name="genero" value="masculino"/> Masculino
                                        <input type="radio" name="genero" value="femenino" class="ms-3"/> Femenino
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Alumno *</label>
                                    <div>
                                        <input type="radio" name="alumno" value="primer_ingreso" onclick="toggleCarne(false)"/> Primer Ingreso
                                        <input type="radio" name="alumno" value="reingreso" class="ms-3" onclick="toggleCarne(true)"/> Reingreso
                                    </div>
                                </div>
                                <div class="mb-3 d-none" id="campo_carne">
                                    <label class="form-label">Número de Carné</label>
                                    <input type="text" name="carne" class="form-control" placeholder="Letras y números"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Dirección vivienda</label>
                                    <textarea name="direccion_vivienda" class="form-control" rows="3"></textarea>
                                    <small class="text-muted">Opcional</small>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Departamento Regional *</label>
                                    <input type="text" name="departamento" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Municipio Regional *</label>
                                    <input type="text" name="municipio" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">¿Cómo se enteró de Kinal? *</label>
                                    <select name="como_se_entero" id="como_se_entero" class="form-select" onchange="toggleRecomendante(this.value)">
                                        <option value="">Seleccione...</option>
                                        <option value="compañero_trabajo">Compañero de Trabajo</option>
                                        <option value="familiar">Familiar</option>
                                        <option value="conocido">De un Conocido</option>
                                        <option value="exalumno_basicos">Soy Exalumno de Básicos</option>
                                        <option value="exalumno_diversificado">Soy Exalumno de Diversificado</option>
                                        <option value="alumno_basicos">Soy Alumno de Básicos</option>
                                        <option value="alumno_diversificado">Soy Alumno de Diversificado</option>
                                        <option value="empresa_familiar">Por la Empresa Familiar</option>
                                        <option value="facebook">Facebook</option>
                                        <option value="instagram">Instagram</option>
                                        <option value="otros">Otros</option>
                                    </select>
                                </div>
                                <div class="mb-3 d-none" id="campo_recomendante">
                                    <label class="form-label">Nombre de quien lo recomendó</label>
                                    <input type="text" name="nombre_recomendante" class="form-control"/>
                                </div>
                                <div class="mb-3 d-none" id="campo_parentesco">
                                    <label class="form-label">Parentesco</label>
                                    <input type="text" name="parentesco" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Último Grado Aprobado *</label>
                                    <input type="text" name="ultimo_grado" class="form-control"/>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevStep(2)">← Anterior</button>
                                    <button type="button" class="btn btn-primary" onclick="nextStep(2)">Siguiente →</button>
                                </div>
                            </div>

                            <!-- PASO 3 -->
                            <div class="step d-none" id="step-3">
                                <h4 class="mb-3" style="color:#008f8c;">Paso 3: Datos Laborales y Facturación</h4>

                                <div class="mb-3">
                                    <label class="form-label">Empresa donde Labora</label>
                                    <input type="text" name="empresa" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Teléfono de la Empresa</label>
                                    <input type="text" name="telefono_empresa" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">¿Cuál es el puesto que desempeña?</label>
                                    <input type="text" name="puesto" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Dirección de la Empresa</label>
                                    <input type="text" name="direccion_empresa" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">¿La empresa le paga los estudios?</label>
                                    <div>
                                        <input type="radio" name="empresa_paga" value="si"/> Sí
                                        <input type="radio" name="empresa_paga" value="no" class="ms-3"/> No
                                        <input type="radio" name="empresa_paga" value="parcial" class="ms-3"/> Parcial
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Emitir recibo a nombre de:</label>
                                    <input type="text" name="recibo_nombre" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">NIT:</label>
                                    <input type="text" name="nit" class="form-control"/>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Posee Vehículo</label>
                                    <div>
                                        <input type="radio" name="posee_vehiculo" value="si" onclick="toggleVehiculo(true)"/> Sí
                                        <input type="radio" name="posee_vehiculo" value="no" class="ms-3" onclick="toggleVehiculo(false)"/> No
                                    </div>
                                </div>
                                <div class="mb-3 d-none" id="campo_vehiculo">
                                    <div class="mb-2">
                                        <label class="form-label">Tipo de Vehículo</label>
                                        <select name="tipo_vehiculo" class="form-select">
                                            <option value="">Seleccione...</option>
                                            <option value="carro">Carro</option>
                                            <option value="moto">Moto</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label">Placa</label>
                                        <input type="text" name="placa_vehiculo" class="form-control"/>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevStep(3)">← Anterior</button>
                                    <button type="button" class="btn btn-primary" onclick="nextStep(3)">Siguiente →</button>
                                </div>
                            </div>

                            <!-- PASO 4 -->
                            <div class="step d-none" id="step-4">
                                <h4 class="mb-3" style="color:#008f8c;">Paso 4: Condiciones de Estudio</h4>
                                <div class="mb-3">
                                    <div class="border p-3 mb-2" style="max-height:200px;overflow-y:scroll;font-size:0.85em;">
                                        Declaro que: He recibido la Normativa de Evaluación y Convivencia de la Escuela Técnica Superior Kinal y me comprometo a cumplirla. Conozco lo señalado en Actitud y Presentación personal, así como Uso y Cuidado de las Instalaciones, y me obligo a no incurrir en ninguna Falta que ponga en riesgo la continuidad de mis estudios. Comprendo que Fundación Kinal ofrece a jóvenes y adultos una formación integral a través de distintos programas educativos, por lo que me comprometo a realizar puntualmente los aportes económicos que correspondan a mis estudios dentro de los primeros cinco días de cada mes, sin necesidad de cobro o requerimiento alguno. Acepto las medidas oportunas de la Escuela Técnica Superior Kinal si incurriere en atraso a partir de dos meses en los aportes convenidos. Informaré lo más rápido posible a la Escuela Técnica Superior Kinal cuando por algún motivo no pueda continuar con mis estudios. Todos los cursos o carreras técnicas deberán contar con un número mínimo de alumnos para su apertura. NOTA: No se hace ningún reembolsó si después de inscrito el estudiante, no se presenta a clases o si decide retirarse antes o después de iniciadas las actividades de la Carrera Técnica.
                                    </div>
                                    <div>
                                        <input type="checkbox" name="acepta_condiciones" value="1" required="1"/>
                                        <label> Acepto las condiciones de estudio *</label>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevStep(4)">← Anterior</button>
                                    <button type="submit" class="btn btn-success btn-lg">Enviar</button>
                                </div>
                            </div>

                        </form>
                    </div>
                </div>
            </div>

            <script>
                function nextStep(current) {
                    document.getElementById('step-' + current).classList.add('d-none');
                    document.getElementById('step-' + (current + 1)).classList.remove('d-none');
                    updateIndicators(current + 1);
                    window.scrollTo(0, 0);
                }
                function prevStep(current) {
                    document.getElementById('step-' + current).classList.add('d-none');
                    document.getElementById('step-' + (current - 1)).classList.remove('d-none');
                    updateIndicators(current - 1);
                    window.scrollTo(0, 0);
                }
                function updateIndicators(active) {
                    for (var i = 1; i &lt;= 4; i++) {
                        var circle = document.querySelector('#ind-' + i + ' div');
                        circle.style.background = (i === active) ? '#008f8c' : '#ccc';
                    }
                }
                function actualizarEdad(val) {
                    val = parseInt(val);
                    if (!isNaN(val)) {
                        document.getElementById('edad_menor').disabled = val >= 18;
                        document.getElementById('edad_mayor').disabled = val &lt; 18;
                        if (val >= 18) {
                            document.getElementById('edad_mayor').checked = true;
                        } else {
                            document.getElementById('edad_menor').checked = true;
                        }
                    }
                }
                function toggleCarne(show) {
                    document.getElementById('campo_carne').classList.toggle('d-none', !show);
                }
                function toggleRecomendante(val) {
                    var showNombre = ['compañero_trabajo', 'familiar', 'conocido'].includes(val);
                    var showParentesco = val === 'familiar';
                    document.getElementById('campo_recomendante').classList.toggle('d-none', !showNombre);
                    document.getElementById('campo_parentesco').classList.toggle('d-none', !showParentesco);
                }
                function toggleVehiculo(show) {
                    document.getElementById('campo_vehiculo').classList.toggle('d-none', !show);
                }
            </script>
        </t>
    </template>
</odoo>
