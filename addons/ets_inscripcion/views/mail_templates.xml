<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_inscripcion" model="mail.template">
            <field name="name">Correo proceso inscripción</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="subject">Proceso de Inscripción Curso de Escuela Técnica Superior Kinal</field>
            <field name="email_to">{{ object.email_from }}</field>
            <field name="body_html" type="html">
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0;padding:20px 0;border-collapse:collapse;background-color:#f4f6f9;">
    <tbody>
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;border-radius:8px;padding:30px;font-family:Arial,Helvetica,sans-serif;">
                    <tbody>
                        <tr>
                            <td style="font-size:22px;font-weight:bold;padding-bottom:10px;color:#333333;background-color:#f4f6f9;">
                                Estimado/a <t t-out="object.display_name"/>:
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size:15px;line-height:1.6;padding-bottom:15px;color:#333333;background-color:#f4f6f9;">
                                Reciba un cordial saludo.
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size:15px;line-height:1.6;padding-bottom:15px;color:#333333;background-color:#f4f6f9;">
                                Agradecemos su interés en la carrera <strong><t t-out="object.x_CarreraISTMO"/></strong>.<br/>
                                O al curso <t t-out="object.x_CarreraTecnica"/><br/><br/>
                                Para continuar con su proceso de inscripción, haga clic en el siguiente botón:
                            </td>
                        </tr>
                        <tr>
                            <td align="center" style="padding:25px 0;background-color:#f4f6f9;">
                                <a t-att-href="'http://crm-ets.kinal.edu.gt:8069/carreras-tecnicas?token=' + (object.x_token or '')"
                                   style="background-color:#008f8c;color:#ffffff;text-decoration:none;padding:14px 28px;font-size:16px;border-radius:5px;display:inline-block;font-weight:bold;">
                                    Completar Proceso de Inscripción
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td style="font-size:13px;color:#666666;line-height:1.5;background-color:#f4f6f9;">
                                Si el botón no funciona, copie y pegue el siguiente enlace en su navegador:<br/><br/>
                                http://crm-ets.kinal.edu.gt:8069/carreras-tecnicas?token=<t t-out="object.x_token"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding-top:30px;font-size:15px;line-height:1.6;color:#333333;background-color:#f4f6f9;">
                                Quedamos atentos para apoyarle en cualquier duda o consulta adicional.<br/><br/>
                                Atentamente,<br/>
                                <strong>Departamento de Admisiones</strong>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </td>
        </tr>
    </tbody>
</table>
            </field>
        </record>
    </data>
</odoo>
